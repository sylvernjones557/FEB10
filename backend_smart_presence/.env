# ══════════════════════════════════════════════════
# CPU-ONLY Performance Optimization (Low-Power Mode)
# ══════════════════════════════════════════════════

# Force CPU — never attempt GPU detection
FACE_DEVICE_PREFERENCE=cpu

# Detector input size: 320 = good balance, use 160 for extremely slow CPUs
FACE_DET_SIZE_CPU=320

# Smallest & fastest model (buffalo_sc). Alternatives: buffalo_m (medium), buffalo_l (large/slow)
FACE_MODEL_NAME=buffalo_sc

# Max image dimension before processing — images are auto-downscaled to this
# Lower = faster. 480-640 works well for face recognition
MAX_IMAGE_DIMENSION=640

# ONNX Runtime threads: 2 for low-power CPU, increase for faster CPUs
ONNX_NUM_THREADS=2

# Single uvicorn worker — minimizes memory & CPU contention
UVICORN_WORKERS=1

# Lazy-load the face model (loads on first request, not at server startup)
LAZY_LOAD_ENGINE=true

# Image quality for processing
IMAGE_QUALITY=80
