# Database (Local SQLite - no internet needed)
DATABASE_URL=sqlite:///./db/sqlite/smart_presence.db

# App Settings
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_FOR_PRODUCTION
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# CPU-ONLY Performance Optimization
FACE_DEVICE_PREFERENCE=cpu
FACE_DET_SIZE_CPU=320
FACE_MODEL_NAME=buffalo_sc
MAX_IMAGE_DIMENSION=640
ONNX_NUM_THREADS=2
UVICORN_WORKERS=1
LAZY_LOAD_ENGINE=true
IMAGE_QUALITY=80
