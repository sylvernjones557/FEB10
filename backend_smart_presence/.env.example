# Database Connection (Supabase PostgreSQL)
# Get from Project Settings > Database > Connection URI
# Typically looks like: postgresql://postgres.abcdef:[PASSWORD]@aws-0-region.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Supabase API URL
# Get from Project Settings > API > Project URL
SUPABASE_URL=https://[PROJECT-REF].supabase.co

# Supabase Service Role Key (Keep this secret!)
# Get from Project Settings > API > Project API keys > service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# App Settings
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING
ACCESS_TOKEN_EXPIRE_MINUTES=11520
