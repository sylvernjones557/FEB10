# ===================================================
# Smart Presence Backend — Environment Variables
# Copy this file to .env and fill in your values
# ===================================================

# Database Connection (Supabase PostgreSQL)
# URL-encode special characters in your password (e.g. @ → %40)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Supabase API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=YOUR_SUPABASE_ANON_KEY

# JWT Secret (generate a random 32+ char string)
JWT_SECRET=your-secret-key-change-this

# Server
HOST=0.0.0.0
PORT=8000

# CPU Optimization (for low-end devices)
# Uncomment these for systems with limited CPU/RAM:
# CUDA_VISIBLE_DEVICES=
# ONNXRUNTIME_PROVIDERS=CPUExecutionProvider
# OMP_NUM_THREADS=2
# OMP_WAIT_POLICY=PASSIVE
